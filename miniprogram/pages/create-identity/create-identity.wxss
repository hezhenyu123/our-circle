/* pages/create-identity/create-identity.wxss */
.page-create {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #FFF0E1 0, #FFF7ED 220rpx, #F3FAF5 220rpx, #F6F3EE 100%);
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* 预览卡片 */
.preview-card {
  background: linear-gradient(180deg, #FFFDFB, #FFF5E9);
  border-radius: 34rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 14rpx 32rpx rgba(194, 170, 157, 0.14);
}

.preview-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.preview-avatar-emoji {
  font-size: 64rpx;
}

.preview-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #2F2A26;
}

.preview-grade {
  font-size: 24rpx;
  color: #8C7F76;
}

/* 表单区块 */
.form-section {
  background: linear-gradient(180deg, rgba(255, 252, 248, 0.97), rgba(244, 250, 246, 0.92));
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 12rpx 28rpx rgba(194, 170, 157, 0.1);
}

.form-label {
  font-size: 26rpx;
  color: #8C7F76;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  font-size: 32rpx;
  color: #2F2A26;
  border-bottom: 2rpx solid #F0E4DA;
  padding: 12rpx 0;
}

/* 头像选择 */
.avatar-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.avatar-option {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FFF3EA, #F3FAF5);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.avatar-option.selected {
  border-color: #F56B6F;
  background: #FFEAE6;
  transform: scale(1.06);
}

.avatar-emoji {
  font-size: 40rpx;
}

/* 自定义头像 */
.custom-avatar {
  position: relative;
  overflow: hidden;
}

.custom-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
}

.custom-avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
}

.custom-avatar-icon {
  font-size: 28rpx;
  line-height: 1;
}

.custom-avatar-text {
  font-size: 16rpx;
  color: #9A8C82;
  line-height: 1;
}

.preview-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* 年级选择 */
.grade-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.grade-btn {
  padding: 12rpx 28rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #FFF3EA, #F4FBF7);
  font-size: 26rpx;
  color: #6C6058;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.grade-btn.selected {
  background: #FFEAE6;
  border-color: #F56B6F;
  color: #F56B6F;
  font-weight: 600;
}

/* 颜色选择 */
.color-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.color-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.color-option.selected {
  border-color: #2F2A26;
  background: linear-gradient(135deg, #FFF7EF, #F2FAF4);
}

.color-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}

.color-name {
  font-size: 20rpx;
  color: #9A8C82;
}

/* 提交按钮 */
.submit-area {
  margin-top: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #F56B6F, #FF8E77);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(245, 107, 111, 0.24);
  transition: all 0.3s ease;
}

.submit-btn.disabled {
  background: #D9D9D9;
  box-shadow: none;
  opacity: 0.7;
}

.submit-btn:active:not(.disabled) {
  transform: scale(0.97);
}

.delete-btn {
  width: 100%;
  height: 80rpx;
  color: #C8646A;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  background: #FFF1F2;
  border-radius: 40rpx;
}

.delete-btn:active {
  background: #FFE4E5;
}
