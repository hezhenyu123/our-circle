/* pages/create-identity/create-identity.wxss */
.page-create {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* 预览卡片 */
.preview-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.preview-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.preview-avatar-emoji {
  font-size: 64rpx;
}

.preview-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.preview-grade {
  font-size: 24rpx;
  color: #999;
}

/* 表单区块 */
.form-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  font-size: 32rpx;
  color: #333;
  border-bottom: 2rpx solid #F0F0F0;
  padding: 12rpx 0;
}

/* 头像选择 */
.avatar-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.avatar-option {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.avatar-option.selected {
  border-color: #FF6B6B;
  background: #FFF0F0;
  transform: scale(1.1);
}

.avatar-emoji {
  font-size: 40rpx;
}

/* 自定义头像 */
.custom-avatar {
  position: relative;
  overflow: hidden;
}

.custom-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.custom-avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
}

.custom-avatar-icon {
  font-size: 28rpx;
  line-height: 1;
}

.custom-avatar-text {
  font-size: 16rpx;
  color: #999;
  line-height: 1;
}

.preview-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* 年级选择 */
.grade-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.grade-btn {
  padding: 12rpx 28rpx;
  border-radius: 20rpx;
  background: #F5F5F5;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.grade-btn.selected {
  background: #FFE8E8;
  border-color: #FF6B6B;
  color: #FF6B6B;
  font-weight: 600;
}

/* 颜色选择 */
.color-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.color-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.color-option.selected {
  border-color: #333;
  background: #F8F8F8;
}

.color-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}

.color-name {
  font-size: 20rpx;
  color: #999;
}

/* 提交按钮 */
.submit-area {
  margin-top: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
}

.submit-btn.disabled {
  background: #D9D9D9;
  box-shadow: none;
  opacity: 0.7;
}

.submit-btn:active:not(.disabled) {
  transform: scale(0.97);
}

.delete-btn {
  width: 100%;
  height: 80rpx;
  color: #FF4444;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  background: #FFF5F5;
  border-radius: 40rpx;
}

.delete-btn:active {
  background: #FFE0E0;
}
