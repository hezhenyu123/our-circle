/* pages/post/post.wxss */
.page-post {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #FFF0E1 0, #FFF8EE 200rpx, #F5FBF6 200rpx, #F6F3EE 100%);
}

/* 顶部栏 - 已改用原生导航栏，此样式保留备用 */
.post-header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #FFFFFF;
}

/* 固定底部提交按钮 */
.fixed-submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 252, 248, 0.96);
  box-shadow: 0 -10rpx 24rpx rgba(194, 170, 157, 0.12);
  z-index: 100;
}

.submit-btn-full {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #F56B6F, #FF8E77);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(245, 107, 111, 0.24);
  transition: all 0.3s ease;
}

.submit-btn-full.disabled {
  background: #D9D9D9;
  box-shadow: none;
  opacity: 0.7;
  pointer-events: none;
}

/* 类型选择 */
.type-selector {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 60rpx 40rpx;
  background:
    radial-gradient(circle at top, rgba(255, 215, 198, 0.52), transparent 34%),
    linear-gradient(180deg, #FFF8F3, #F7F0EA);
}

.selector-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.selector-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #2F2A26;
  margin-bottom: 16rpx;
}

.selector-subtitle {
  font-size: 28rpx;
  color: #8B7C73;
}

.type-options {
  display: flex;
  gap: 48rpx;
  margin-bottom: 80rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  width: 220rpx;
  padding: 26rpx 18rpx;
  background: linear-gradient(180deg, rgba(255, 252, 248, 0.97), rgba(255, 249, 241, 0.93));
  border-radius: 30rpx;
  box-shadow: 0 12rpx 28rpx rgba(194, 170, 157, 0.12);
}

.type-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-bg {
  background: linear-gradient(135deg, #FFE4E6, #FFF0F1);
}

.photo-bg {
  background: linear-gradient(135deg, #DCF5E8, #EEFBEF);
}

.draw-bg {
  background: linear-gradient(135deg, #F4E6FA, #FAF0FF);
}

.text-bg {
  background: linear-gradient(135deg, #FFF1CB, #FFF8E1);
}

.type-icon {
  font-size: 64rpx;
}

.type-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2F2A26;
}

.type-desc {
  font-size: 24rpx;
  color: #8C7F76;
}

.cancel-btn {
  padding: 20rpx 48rpx;
  color: #8C7F76;
  font-size: 28rpx;
}

/* 录音区域 */
.voice-post {
  padding-bottom: 200rpx;
}

.record-area {
  padding: 60rpx 24rpx;
  text-align: center;
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.record-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.hint-icon {
  font-size: 80rpx;
}

.hint-text {
  font-size: 32rpx;
  color: #2F2A26;
  font-weight: 500;
}

.hint-sub {
  font-size: 24rpx;
  color: #8C7F76;
}

/* 录音中动画 */
.recording {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.recording-wave {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  height: 80rpx;
}

.wave-bar {
  width: 12rpx;
  background: #F56B6F;
  border-radius: 6rpx;
  animation: wave 0.8s ease-in-out infinite alternate;
}

.wave-bar:nth-child(1) { height: 30rpx; animation-delay: 0s; }
.wave-bar:nth-child(2) { height: 50rpx; animation-delay: 0.1s; }
.wave-bar:nth-child(3) { height: 70rpx; animation-delay: 0.2s; }
.wave-bar:nth-child(4) { height: 40rpx; animation-delay: 0.3s; }
.wave-bar:nth-child(5) { height: 60rpx; animation-delay: 0.4s; }

@keyframes wave {
  0% { transform: scaleY(0.5); }
  100% { transform: scaleY(1.5); }
}

.recording-time {
  font-size: 36rpx;
  font-weight: 700;
  color: #F56B6F;
}

.recording-hint {
  font-size: 24rpx;
  color: #8C7F76;
}

/* 录音结果 - 语音预览气泡 */
.record-result {
  width: 100%;
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.record-done-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #EAF7EF;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

.done-check {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 700;
}

.done-text {
  font-size: 26rpx;
  color: #4CAF50;
  font-weight: 500;
}

.voice-preview-bubble {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: linear-gradient(135deg, #AEE483, #97D86E);
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  min-width: 280rpx;
  max-width: 500rpx;
}

.voice-preview-icon {
  font-size: 32rpx;
}

.voice-preview-bars {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.vbar {
  width: 6rpx;
  border-radius: 3rpx;
  background: rgba(0, 0, 0, 0.25);
}

.vbar:nth-child(1) { height: 12rpx; }
.vbar:nth-child(2) { height: 24rpx; }
.vbar:nth-child(3) { height: 32rpx; }
.vbar:nth-child(4) { height: 20rpx; }
.vbar:nth-child(5) { height: 14rpx; }

.voice-preview-duration {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.5);
}

.emoji-stickers {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.sticker {
  font-size: 40rpx;
  background: #FFF8E1;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.redo-btn {
  margin-top: 24rpx;
  text-align: center;
  color: #F56B6F;
  font-size: 28rpx;
  padding: 12rpx 0;
}

/* 录音按钮 */
.record-btn-wrap {
  position: fixed;
  bottom: 100rpx;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.record-btn {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F56B6F, #FF8E77);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 32rpx rgba(245, 107, 111, 0.28);
  transition: transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.18s ease;
}

/* 按下瞬间触感（非录音状态下短暂闪现） */
.record-btn-pressed {
  transform: scale(0.92);
  box-shadow: 0 6rpx 14rpx rgba(245, 107, 111, 0.38);
}

/* 录音中：放大 + 深色 + 脉冲呼吸 + 外圈光晕 */
.record-btn.recording {
  background: linear-gradient(135deg, #E85A61, #F56B6F);
  box-shadow: 0 16rpx 42rpx rgba(245, 107, 111, 0.42);
  animation: recordPulse 1.1s ease-in-out infinite;
}

.record-btn.recording::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(245, 107, 111, 0.45);
  animation: recordRing 1.6s ease-out infinite;
  pointer-events: none;
}

@keyframes recordPulse {
  0%, 100% { transform: scale(1.15); }
  50% { transform: scale(1.22); }
}

@keyframes recordRing {
  0% {
    transform: scale(1);
    opacity: 0.7;
  }
  100% {
    transform: scale(1.45);
    opacity: 0;
  }
}

.record-btn-icon {
  font-size: 60rpx;
  color: #FFFFFF;
  transition: transform 0.2s ease;
}

.record-btn.recording .record-btn-icon {
  animation: micWiggle 0.6s ease-in-out infinite;
}

@keyframes micWiggle {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.12); }
}

.record-btn-text {
  font-size: 24rpx;
  color: #8C7F76;
}

/* 文字发动态 */
.text-post {
  padding-bottom: 40rpx;
}

.text-input-section {
  margin: 24rpx;
  background: linear-gradient(180deg, rgba(255, 252, 248, 0.97), rgba(245, 250, 255, 0.92));
  border-radius: 28rpx;
  padding: 24rpx;
  position: relative;
  box-shadow: 0 12rpx 28rpx rgba(194, 170, 157, 0.1);
}

.text-post-input {
  width: 100%;
  min-height: 240rpx;
  font-size: 32rpx;
  line-height: 48rpx;
  color: #2F2A26;
  box-sizing: border-box;
  padding: 0;
}

.text-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #B6A79B;
  margin-top: 8rpx;
}

.emoji-stickers-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.text-photo-section {
  padding: 0 24rpx 8rpx;
}

.text-photo-trigger {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 22rpx;
  background: linear-gradient(135deg, #FFF2E6, #F3FAFF);
  border-radius: 999rpx;
  color: #6B5F58;
}

.text-photo-icon {
  font-size: 28rpx;
}

.text-photo-label {
  font-size: 24rpx;
  color: #6B5F58;
}

.text-photo-preview {
  position: relative;
  width: 100%;
  margin-top: 18rpx;
}

.text-photo-image {
  width: 100%;
  height: 360rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #F7ECE2, #EEF7FF);
}

.text-photo-remove {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(47, 42, 38, 0.72);
  color: #FFFFFF;
  font-size: 22rpx;
}

.emoji-stickers-preview .sticker {
  font-size: 28rpx;
  background: #FFF8E1;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.quick-emoji-section {
  padding: 24rpx;
}

.quick-emoji-label {
  display: block;
  font-size: 26rpx;
  color: #8C7F76;
  margin-bottom: 16rpx;
}

.quick-emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-emoji-item {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFF2E8, #F6FAFF);
  border-radius: 16rpx;
  font-size: 40rpx;
  border: 3rpx solid transparent;
  transition: transform var(--motion-fast), border-color var(--motion-fast);
}

.quick-emoji-item.selected {
  border-color: var(--accent-primary);
  background: var(--accent-primary-soft);
  transform: scale(1.12);
  box-shadow: 0 6rpx 16rpx rgba(245, 107, 111, 0.22);
}

/* 拍照动态 */
.photo-post {
  padding-bottom: 40rpx;
}

.photo-preview {
  padding: 24rpx;
}

.preview-image {
  width: 100%;
  height: 500rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #F7ECE2, #EEF7FF);
}

/* 心情选择 */
.mood-selector {
  padding: 24rpx;
}

.mood-label {
  font-size: 28rpx;
  color: #6B5F58;
  margin-bottom: 16rpx;
  display: block;
}

.mood-options {
  display: flex;
  gap: 24rpx;
}

.mood-item {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF2E8, #F7FBFF);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  position: relative;
  transition: transform var(--motion-base), border-color var(--motion-base);
}

.mood-item.selected {
  border-color: var(--accent-primary);
  background: var(--accent-primary-soft);
  transform: scale(1.1);
  box-shadow: 0 8rpx 20rpx rgba(245, 107, 111, 0.25);
}

.mood-item.selected::after {
  content: '';
  position: absolute;
  bottom: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--accent-primary);
}

.mood-emoji {
  font-size: 44rpx;
}

/* 文字输入 */
.text-input-area {
  padding: 0 24rpx;
}

.photo-text-input {
  width: 100%;
  min-height: 160rpx;
  background: linear-gradient(180deg, rgba(255, 252, 248, 0.97), rgba(245, 250, 255, 0.92));
  border-radius: 24rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 44rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 28rpx rgba(194, 170, 157, 0.1);
}

/* 画画动态 */
.drawing-post {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  min-height: 60vh;
}

.drawing-preview {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.drawing-preview-image {
  width: 100%;
  max-height: 500rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E0E0E0;
}

.redo-drawing {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  background: #F0F0F0;
  font-size: 28rpx;
  color: #666;
}

.redo-drawing:active {
  background: #E0E0E0;
}

.drawing-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-top: 100rpx;
}

.drawing-empty-icon {
  font-size: 64rpx;
}

.drawing-empty-text {
  font-size: 28rpx;
  color: #8C7F76;
}
