<!-- pages/mine/mine.wxml - 个人主页 -->
<view class="page-mine">
  <!-- 个人信息 -->
  <view class="profile-header">
    <view class="profile-avatar" style="background: {{currentChild.color}}20;">
      <image wx:if="{{currentChild.avatarType === 'image' && currentChild.avatarImageUrl}}" class="profile-avatar-img" src="{{currentChild.avatarImageUrl}}" mode="aspectFill" />
      <text wx:else class="avatar-emoji">{{currentChild.avatar}}</text>
    </view>
    <text class="profile-name">{{currentChild.nickname}}</text>
    <text class="profile-grade">{{currentChild.grade}}年级</text>
  </view>

  <!-- 统计 -->
  <view class="profile-stats">
    <view class="stat-item">
      <text class="stat-num">{{postCount}}</text>
      <text class="stat-label">动态</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{totalLikes}}</text>
      <text class="stat-label">获赞</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{unlockedCount}}</text>
      <text class="stat-label">成就</text>
    </view>
  </view>

  <!-- 操作区 -->
  <view class="profile-actions">
    <view class="action-row" bindtap="onSwitchIdentity">
      <text class="action-label">切换身份</text>
      <text class="action-arrow">›</text>
    </view>
    <view class="action-row" bindtap="onCreateIdentity">
      <text class="action-label">创建新身份</text>
      <text class="action-arrow">›</text>
    </view>
    <view class="action-row action-danger" bindtap="onDeleteIdentity">
      <text class="action-label">删除身份</text>
      <text class="action-hint">需要家长验证</text>
    </view>
    <view class="action-row action-danger" bindtap="onResetData">
      <text class="action-label">重置数据</text>
      <text class="action-hint">需要家长验证</text>
    </view>
  </view>

  <!-- 成就墙 -->
  <view class="section-title">
    <text>我的成就</text>
    <text class="section-sub">{{unlockedCount}}/{{totalAchievements}}</text>
  </view>

  <view class="achievement-wall">
    <view
      class="achievement-item {{item.unlocked ? 'unlocked' : 'locked'}}"
      wx:for="{{showAllAchievements ? achievements : achievements}}"
      wx:key="id"
    >
      <view class="achievement-emoji">{{item.unlocked ? item.emoji : '🔒'}}</view>
      <text class="achievement-name">{{item.unlocked ? item.name : '? ? ?'}}</text>
      <text class="achievement-desc" wx:if="{{item.unlocked}}">{{item.desc}}</text>
      <view class="achievement-progress" wx:if="{{!item.unlocked}}">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{item.progress / item.target * 100}}%;"></view>
        </view>
        <text class="progress-text">{{item.progress}}/{{item.target}}</text>
      </view>
    </view>
  </view>

  <!-- 我的动态 -->
  <view class="section-title">
    <text>我的动态</text>
    <text class="section-sub">{{postCount}}条</text>
  </view>

  <view class="my-posts">
    <view class="empty-state" wx:if="{{myPosts.length === 0}}">
      <text class="empty-emoji">📝</text>
      <text class="empty-title">还没有动态</text>
      <text class="empty-desc">快去圈子发第一条吧！</text>
    </view>

    <view
      class="my-post-card type-{{item.type}}"
      wx:for="{{myPosts}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="onTapPost"
      bindlongpress="onLongPressPost"
    >
      <view class="mpc-type-bar">
        <view class="mpc-type-chip chip-{{item.type}}">
          <text class="mpc-type-emoji">{{item.type === 'voice' ? '🎤' : item.type === 'photo' ? '📸' : item.type === 'text' ? '✏️' : '🎨'}}</text>
          <text class="mpc-type-name">{{item.type === 'voice' ? '语音' : item.type === 'photo' ? '拍照' : item.type === 'text' ? '文字' : '画画'}}</text>
        </view>
        <text class="mpc-time">{{item.timeText}}</text>
      </view>

      <view class="mpc-body" wx:if="{{item.type === 'photo' || item.type === 'drawing'}}">
        <view class="mpc-media-row">
          <image
            class="mpc-thumb-img"
            src="{{item.content.image_url}}"
            mode="aspectFill"
          />
          <view class="mpc-text-side" wx:if="{{item.content.text || item.content.mood_emoji}}">
            <text class="mpc-caption mpc-caption-wrap" wx:if="{{item.content.text}}">{{item.content.text}}</text>
            <text class="mpc-mood" wx:if="{{item.content.mood_emoji}}">{{item.content.mood_emoji}}</text>
          </view>
        </view>
      </view>

      <view class="mpc-body mpc-body-text" wx:elif="{{item.type === 'text'}}">
        <text class="mpc-text-preview" wx:if="{{item.content.text}}">{{item.content.text}}</text>
        <view class="mpc-text-media" wx:if="{{item.content.image_url}}">
          <image class="mpc-text-img" src="{{item.content.image_url}}" mode="aspectFill" />
        </view>
        <view class="mpc-mood-row" wx:if="{{item.content.mood_emoji}}">
          <text class="mpc-mood">{{item.content.mood_emoji}}</text>
        </view>
      </view>

      <view class="mpc-body mpc-body-voice" wx:elif="{{item.type === 'voice'}}">
        <view class="mpc-voice-bubble">
          <text class="mpc-voice-icon">🎤</text>
          <view class="mpc-voice-bars">
            <view class="mpc-vbar"></view>
            <view class="mpc-vbar"></view>
            <view class="mpc-vbar"></view>
            <view class="mpc-vbar"></view>
            <view class="mpc-vbar"></view>
          </view>
          <text class="mpc-voice-dur">{{item.content.voice_duration}}"</text>
        </view>
        <text class="mpc-caption" wx:if="{{item.content.text}}">{{item.content.text}}</text>
      </view>

      <view class="mpc-footer">
        <view class="mpc-stat">
          <text class="mpc-stat-icon">🤍</text>
          <text class="mpc-stat-num">{{item.likes.length}}</text>
        </view>
        <view class="mpc-stat">
          <text class="mpc-stat-icon">💬</text>
          <text class="mpc-stat-num">{{item.commentCount}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 家长验证码弹窗 -->
  <view class="parent-modal-mask" wx:if="{{showParentModal}}" bindtap="onCancelParentCode">
    <view class="parent-modal" catchtap>
      <text class="parent-modal-title">🔐 家长验证</text>
      <text class="parent-modal-desc">请输入4位家长验证码</text>
      <input
        class="parent-code-input"
        type="number"
        maxlength="4"
        placeholder="请输入验证码"
        value="{{parentCode}}"
        bindinput="onParentCodeInput"
        focus="{{showParentModal}}"
      />
      <text class="parent-code-error" wx:if="{{parentCodeError}}">{{parentCodeError}}</text>
      <view class="parent-modal-btns">
        <view class="parent-modal-btn btn-cancel" bindtap="onCancelParentCode">取消</view>
        <view class="parent-modal-btn btn-confirm" bindtap="onConfirmParentCode">确认</view>
      </view>
    </view>
  </view>
</view>
