/* pages/mine/mine.wxss */
.page-mine {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #FFEFDF 0, #FFF7EF 220rpx, #F4FBF5 220rpx, #F6F3EE 100%);
  padding: 20rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx 36rpx;
  background: linear-gradient(180deg, #FFFDFB, #FFF5E9);
  border-radius: 36rpx;
  box-shadow: 0 14rpx 32rpx rgba(194, 170, 157, 0.14);
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 24rpx rgba(214, 188, 175, 0.22);
}

.profile-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-emoji {
  font-size: 72rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2F2A26;
  margin-bottom: 8rpx;
}

.profile-grade {
  font-size: 24rpx;
  color: #8B7C73;
  background: #FFF1E7;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
}

.profile-stats {
  display: flex;
  justify-content: center;
  gap: 80rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, rgba(255, 251, 244, 0.96), rgba(240, 248, 242, 0.93));
  border-radius: 30rpx;
  margin-top: 18rpx;
  box-shadow: 0 12rpx 28rpx rgba(194, 170, 157, 0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #2F2A26;
}

.stat-label {
  font-size: 24rpx;
  color: #9A8C82;
}

.section-title {
  display: flex;
  align-items: baseline;
  padding: 36rpx 4rpx 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #2F2A26;
}

.my-posts {
  padding: 0;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #9A8C82;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  background: rgba(255, 252, 248, 0.88);
  border-radius: 30rpx;
  box-shadow: 0 12rpx 28rpx rgba(194, 170, 157, 0.1);
}

.empty-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #5F534C;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #9A8C82;
}

.my-post-item {
  margin-bottom: 18rpx;
  border-radius: 28rpx;
}

.my-post-main {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.post-summary {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  flex: 1;
  min-width: 0;
}

.summary-type {
  font-size: 32rpx;
}

.summary-text {
  font-size: 28rpx;
  color: #2F2A26;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.post-thumb {
  width: 132rpx;
  height: 132rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #F7ECE2, #EEF7FF);
}

.post-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 4rpx;
}

.meta-time {
  font-size: 22rpx;
  color: #9A8C82;
}

.meta-stats {
  font-size: 22rpx;
  color: #9A8C82;
}

/* 操作区 */
.profile-actions {
  background: linear-gradient(180deg, rgba(255, 252, 248, 0.96), rgba(246, 251, 246, 0.92));
  border-radius: 28rpx;
  margin: 18rpx 0 0;
  overflow: hidden;
  box-shadow: 0 12rpx 28rpx rgba(194, 170, 157, 0.1);
}

.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #F2E7DD;
}

.action-row:last-child {
  border-bottom: none;
}

.action-row:active {
  background: #FFF5EF;
}

.action-danger .action-label {
  color: #B48383;
}

.action-hint {
  font-size: 22rpx;
  color: #C1A6A6;
}

.action-arrow {
  font-size: 36rpx;
  color: #C6B5AA;
}

/* 家长验证码弹窗 */
.parent-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.parent-modal {
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.parent-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2F2A26;
  margin-bottom: 16rpx;
}

.parent-modal-desc {
  font-size: 26rpx;
  color: #8C7F76;
  margin-bottom: 32rpx;
}

.parent-code-input {
  width: 100%;
  height: 80rpx;
  background: #FFF4EC;
  border-radius: 16rpx;
  text-align: center;
  font-size: 36rpx;
  letter-spacing: 16rpx;
  color: #2F2A26;
  margin-bottom: 12rpx;
}

.parent-code-error {
  font-size: 24rpx;
  color: #C8646A;
  margin-bottom: 12rpx;
  height: 32rpx;
}

.parent-modal-btns {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-top: 16rpx;
}

.parent-modal-btn {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-cancel {
  background: #FFF4EC;
  color: #8C7F76;
}

.btn-confirm {
  background: linear-gradient(135deg, #F56B6F, #FF8E77);
  color: #FFFFFF;
  box-shadow: 0 8rpx 18rpx rgba(245, 107, 111, 0.22);
}

.btn-cancel:active {
  background: #E8E8E8;
}

.btn-confirm:active {
  opacity: 0.85;
}
.section-sub {
  font-size: 24rpx;
  font-weight: 400;
  color: #9A8C82;
  margin-left: 12rpx;
}

.achievement-wall {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0;
}

.achievement-item {
  width: calc(50% - 8rpx);
  background: rgba(255, 252, 248, 0.92);
  border-radius: 26rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.3s;
  box-sizing: border-box;
  box-shadow: 0 10rpx 24rpx rgba(194, 170, 157, 0.09);
}

.achievement-item.unlocked {
  background: linear-gradient(135deg, #FFF7DB, #F4FFF2);
  box-shadow: 0 12rpx 24rpx rgba(246, 201, 105, 0.18);
}

.achievement-item.locked {
  opacity: 0.7;
}

.achievement-emoji {
  font-size: 48rpx;
  line-height: 1;
}

.achievement-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2F2A26;
}

.achievement-item.locked .achievement-name {
  color: #998D85;
}

.achievement-desc {
  font-size: 20rpx;
  color: #998D85;
}

.achievement-progress {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #F2E7DD;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFD700, #FFA500);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 20rpx;
  color: #B7A99D;
}
