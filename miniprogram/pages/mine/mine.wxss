/* pages/mine/mine.wxss */
.page-mine {
  min-height: 100vh;
  background: #F5F5F5;
}

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx 32rpx;
  background: #FFFFFF;
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.profile-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-emoji {
  font-size: 72rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.profile-grade {
  font-size: 24rpx;
  color: #999;
  background: #F5F5F5;
  padding: 4rpx 20rpx;
  border-radius: 16rpx;
}

.profile-stats {
  display: flex;
  justify-content: center;
  gap: 80rpx;
  padding: 32rpx 24rpx;
  background: #FFFFFF;
  margin-top: 2rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.section-title {
  padding: 32rpx 24rpx 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.my-posts {
  padding: 0 24rpx;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
}

.my-post-item {
  margin-bottom: 16rpx;
}

.post-summary {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.summary-type {
  font-size: 32rpx;
}

.summary-text {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.post-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.meta-time {
  font-size: 22rpx;
  color: #999;
}

.meta-stats {
  font-size: 22rpx;
  color: #999;
}

/* 操作区 */
.profile-actions {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin: 16rpx 24rpx;
  overflow: hidden;
}

.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.action-row:last-child {
  border-bottom: none;
}

.action-row:active {
  background: #F8F8F8;
}

.action-danger .action-label {
  color: #BBB;
}

.action-hint {
  font-size: 22rpx;
  color: #CCC;
}

.action-arrow {
  font-size: 36rpx;
  color: #CCC;
}

/* 家长验证码弹窗 */
.parent-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.parent-modal {
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.parent-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.parent-modal-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.parent-code-input {
  width: 100%;
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  text-align: center;
  font-size: 36rpx;
  letter-spacing: 16rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.parent-code-error {
  font-size: 24rpx;
  color: #FF6B6B;
  margin-bottom: 12rpx;
  height: 32rpx;
}

.parent-modal-btns {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-top: 16rpx;
}

.parent-modal-btn {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-cancel {
  background: #F5F5F5;
  color: #999;
}

.btn-confirm {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.btn-cancel:active {
  background: #E8E8E8;
}

.btn-confirm:active {
  opacity: 0.85;
}
.section-sub {
  font-size: 24rpx;
  font-weight: 400;
  color: #999;
  margin-left: 12rpx;
}

.achievement-wall {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 24rpx;
}

.achievement-item {
  width: calc(50% - 6rpx);
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.3s;
}

.achievement-item.unlocked {
  background: linear-gradient(135deg, #FFF9E6, #FFFFFF);
  box-shadow: 0 4rpx 16rpx rgba(255, 193, 7, 0.15);
}

.achievement-item.locked {
  opacity: 0.7;
}

.achievement-emoji {
  font-size: 48rpx;
  line-height: 1;
}

.achievement-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.achievement-item.locked .achievement-name {
  color: #999;
}

.achievement-desc {
  font-size: 20rpx;
  color: #999;
}

.achievement-progress {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #F0F0F0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFD700, #FFA500);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 20rpx;
  color: #CCC;
}
