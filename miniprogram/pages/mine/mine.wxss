/* pages/mine/mine.wxss */
.page-mine {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #FFEFDF 0, #FFF7EF 220rpx, #F4FBF5 220rpx, #F6F3EE 100%);
  padding: 20rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx 36rpx;
  background: linear-gradient(180deg, #FFFDFB, #FFF5E9);
  border-radius: 36rpx;
  box-shadow: 0 14rpx 32rpx rgba(194, 170, 157, 0.14);
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 24rpx rgba(214, 188, 175, 0.22);
}

.profile-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-emoji {
  font-size: 72rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2F2A26;
  margin-bottom: 8rpx;
}

.profile-grade {
  font-size: 24rpx;
  color: #8B7C73;
  background: #FFF1E7;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
}

.profile-stats {
  display: flex;
  justify-content: center;
  gap: 80rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, rgba(255, 251, 244, 0.96), rgba(240, 248, 242, 0.93));
  border-radius: 30rpx;
  margin-top: 18rpx;
  box-shadow: 0 12rpx 28rpx rgba(194, 170, 157, 0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #2F2A26;
}

.stat-label {
  font-size: 24rpx;
  color: #9A8C82;
}

.section-title {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 48rpx 4rpx 20rpx;
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  position: relative;
}

.section-title::before {
  content: '';
  position: absolute;
  top: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--line-soft), transparent);
}

.section-title .section-sub {
  font-weight: 400;
}

.my-posts {
  padding: 0;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #9A8C82;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  background: rgba(255, 252, 248, 0.88);
  border-radius: 30rpx;
  box-shadow: 0 12rpx 28rpx rgba(194, 170, 157, 0.1);
}

.empty-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #5F534C;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #9A8C82;
}

.my-post-card {
  margin-bottom: 20rpx;
  border-radius: 28rpx;
  padding: 24rpx;
  background: #FFFCF8;
  border: 1rpx solid rgba(243, 226, 215, 0.9);
  box-shadow: 0 10rpx 24rpx rgba(194, 170, 157, 0.1);
  transition: transform 0.15s ease;
}

.my-post-card:active {
  transform: scale(0.985);
}

.my-post-card.type-photo {
  background: linear-gradient(180deg, #FFFDFC, #FFF7EF);
}

.my-post-card.type-drawing {
  background: linear-gradient(180deg, #FFFEFC, #F3FBF6);
}

.my-post-card.type-voice {
  background: linear-gradient(180deg, #FFFEFC, #F3F8FF);
}

.my-post-card.type-text {
  background: linear-gradient(180deg, #FFFDFC, #FFF9F4);
}

.mpc-type-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.mpc-type-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.chip-photo {
  background: linear-gradient(135deg, #FFE8DD, #FFF1E7);
}

.chip-drawing {
  background: linear-gradient(135deg, #DDF5EA, #EAF7F0);
}

.chip-voice {
  background: linear-gradient(135deg, #DDF0FF, #E8F3FA);
}

.chip-text {
  background: linear-gradient(135deg, #FFF3D7, #FFF8E7);
}

.mpc-type-emoji {
  font-size: 24rpx;
}

.mpc-type-name {
  font-size: 22rpx;
  font-weight: 500;
  color: #7A6F68;
}

.mpc-time {
  font-size: 22rpx;
  color: #B3A59A;
}

.mpc-body {
  margin-bottom: 16rpx;
}

.mpc-media-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.mpc-thumb-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  background: #F1EAE3;
}

.mpc-text-side {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.mpc-caption {
  display: block;
  font-size: 26rpx;
  color: #5A4E47;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mpc-caption-wrap {
  white-space: normal;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mpc-body-text {
  padding: 4rpx 0;
}

.mpc-text-preview {
  font-size: 30rpx;
  color: #2F2A26;
  line-height: 1.65;
  word-break: break-all;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.mpc-text-media {
  margin-top: 12rpx;
}

.mpc-text-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  background: #F1EAE3;
}

.mpc-mood-row {
  margin-top: 10rpx;
}

.mpc-mood {
  font-size: 40rpx;
}

.mpc-body-voice {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.mpc-voice-bubble {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #AEE483, #97D86E);
  border-radius: 24rpx;
  padding: 18rpx 22rpx;
  gap: 12rpx;
  min-width: 200rpx;
  max-width: 380rpx;
}

.mpc-voice-icon {
  font-size: 28rpx;
}

.mpc-voice-bars {
  display: flex;
  align-items: center;
  gap: 5rpx;
  flex: 1;
}

.mpc-vbar {
  width: 5rpx;
  border-radius: 3rpx;
  background: rgba(0, 0, 0, 0.18);
}

.mpc-vbar:nth-child(1) { height: 8rpx; }
.mpc-vbar:nth-child(2) { height: 18rpx; }
.mpc-vbar:nth-child(3) { height: 26rpx; }
.mpc-vbar:nth-child(4) { height: 16rpx; }
.mpc-vbar:nth-child(5) { height: 10rpx; }

.mpc-voice-dur {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.4);
}

.mpc-footer {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F3E6DB;
}

.mpc-stat {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.mpc-stat-icon {
  font-size: 28rpx;
}

.mpc-stat-num {
  font-size: 24rpx;
  color: #9A8C82;
}

/* 操作区 */
.profile-actions {
  background: linear-gradient(180deg, rgba(255, 252, 248, 0.96), rgba(246, 251, 246, 0.92));
  border-radius: 28rpx;
  margin: 18rpx 0 0;
  overflow: hidden;
  box-shadow: 0 12rpx 28rpx rgba(194, 170, 157, 0.1);
}

.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #F2E7DD;
}

.action-row:last-child {
  border-bottom: none;
}

.action-row:active {
  background: #FFF5EF;
}

.action-danger .action-label {
  color: #B48383;
}

.action-hint {
  font-size: 22rpx;
  color: #C1A6A6;
}

.action-arrow {
  font-size: 36rpx;
  color: #C6B5AA;
}

/* 家长验证码弹窗 */
.parent-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.parent-modal {
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.parent-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2F2A26;
  margin-bottom: 16rpx;
}

.parent-modal-desc {
  font-size: 26rpx;
  color: #8C7F76;
  margin-bottom: 32rpx;
}

.parent-code-input {
  width: 100%;
  height: 80rpx;
  background: #FFF4EC;
  border-radius: 16rpx;
  text-align: center;
  font-size: 36rpx;
  letter-spacing: 16rpx;
  color: #2F2A26;
  margin-bottom: 12rpx;
}

.parent-code-error {
  font-size: 24rpx;
  color: #C8646A;
  margin-bottom: 12rpx;
  height: 32rpx;
}

.parent-modal-btns {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-top: 16rpx;
}

.parent-modal-btn {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-cancel {
  background: #FFF4EC;
  color: #8C7F76;
}

.btn-confirm {
  background: linear-gradient(135deg, #F56B6F, #FF8E77);
  color: #FFFFFF;
  box-shadow: 0 8rpx 18rpx rgba(245, 107, 111, 0.22);
}

.btn-cancel:active {
  background: #E8E8E8;
}

.btn-confirm:active {
  opacity: 0.85;
}
.section-sub {
  font-size: 24rpx;
  font-weight: 400;
  color: #9A8C82;
  margin-left: 12rpx;
}

.achievement-wall {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0;
}

.achievement-item {
  width: calc(50% - 8rpx);
  background: rgba(255, 252, 248, 0.92);
  border-radius: 26rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.3s;
  box-sizing: border-box;
  box-shadow: 0 10rpx 24rpx rgba(194, 170, 157, 0.09);
}

.achievement-item.unlocked {
  background: linear-gradient(135deg, #FFF7DB, #F4FFF2);
  box-shadow: 0 12rpx 24rpx rgba(246, 201, 105, 0.18);
}

.achievement-item.locked {
  opacity: 0.7;
}

.achievement-emoji {
  font-size: 48rpx;
  line-height: 1;
}

.achievement-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2F2A26;
}

.achievement-item.locked .achievement-name {
  color: #998D85;
}

.achievement-desc {
  font-size: 20rpx;
  color: #998D85;
}

.achievement-progress {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #F2E7DD;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFD700, #FFA500);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 20rpx;
  color: #B7A99D;
}
