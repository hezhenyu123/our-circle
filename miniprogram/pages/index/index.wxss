/* pages/index/index.wxss */
.page-index {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background:
    linear-gradient(180deg, #FFF2EA 0, #FFF7F1 200rpx, #F6F3EE 200rpx, #F6F3EE 100%);
}

/* 无身份引导页 */
.no-identity {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 0 60rpx;
  background:
    radial-gradient(circle at top, rgba(255, 214, 198, 0.55), transparent 38%),
    linear-gradient(180deg, #FFF5EE, #F7F0EA);
}

.no-identity-emoji {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.no-identity-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2F2A26;
  margin-bottom: 16rpx;
}

.no-identity-desc {
  font-size: 28rpx;
  color: #7A6F68;
  margin-bottom: 48rpx;
  text-align: center;
  line-height: 1.6;
}

.no-identity-btn {
  width: 360rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #F56B6F, #FF8E77);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 30rpx rgba(245, 107, 111, 0.28);
}

.no-identity-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.no-identity-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 18rpx 24rpx 12rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(255, 252, 248, 0.97), rgba(255, 245, 236, 0.96));
  border: 1rpx solid rgba(244, 228, 218, 0.9);
  border-radius: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(194, 170, 157, 0.14);
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #2F2A26;
}

.grade-tag {
  font-size: 22rpx;
  color: #8B7C73;
  background: linear-gradient(135deg, #FFF3D7, #FFECDD);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.switch-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 18rpx;
  background: linear-gradient(135deg, #E8F7EE, #F3FBF7);
  border-radius: 999rpx;
}

.switch-text {
  font-size: 24rpx;
  color: #4E8F79;
}

.switch-icon {
  font-size: 20rpx;
  color: #6FAA93;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.parent-mode-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FFF3DE, #FFF8EC);
  transition: all 0.2s;
}

.parent-mode-btn.active {
  background: #EAF7EF;
}

.parent-mode-icon {
  font-size: 28rpx;
}

.parent-mode-text {
  font-size: 22rpx;
  color: #4CAF50;
  font-weight: 500;
}

.parent-mode-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin: 0 24rpx 12rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(90deg, #ECF8EF, #F5FBF4);
  border: 1rpx solid #D7ECDD;
  border-radius: 24rpx;
}

.banner-icon {
  font-size: 28rpx;
}

.banner-text {
  font-size: 24rpx;
  color: #477C58;
  font-weight: 500;
}

.banner-close {
  font-size: 28rpx;
  color: #8CA18F;
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
}

/* 账户切换面板 */
.account-switcher {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.switcher-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
}

.switcher-panel {
  position: absolute;
  top: 120rpx;
  left: 24rpx;
  background: #FFFDF9;
  border-radius: 30rpx;
  padding: 26rpx;
  box-shadow: 0 20rpx 42rpx rgba(89, 73, 65, 0.16);
  min-width: 400rpx;
}

.switcher-title {
  font-size: 28rpx;
  color: #8C7F76;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.switcher-item {
  display: flex;
  align-items: center;
  padding: 16rpx 10rpx;
  border-radius: 20rpx;
}

.switcher-tap-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.switcher-edit {
  font-size: 24rpx;
  color: #5FAE9B;
  padding: 8rpx 16rpx;
  background: #EAF7F3;
  border-radius: 999rpx;
}

.switcher-item.active {
  background: linear-gradient(135deg, #FFF1E9, #FFF8E7);
}

.switcher-name {
  font-size: 30rpx;
  color: #2F2A26;
}

.switcher-grade {
  font-size: 22rpx;
  color: #9C8E84;
}

.switcher-check {
  margin-left: auto;
  color: #F56B6F;
  font-size: 28rpx;
  font-weight: bold;
}

.switcher-add {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  margin-top: 8rpx;
  border-top: 2rpx solid #F3E6DB;
}

.switcher-add-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F56B6F, #FF8E77);
  color: #FFFFFF;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 48rpx;
  text-align: center;
}

.switcher-add-text {
  font-size: 28rpx;
  color: #F56B6F;
  font-weight: 500;
}

/* 动态列表 */
.post-list {
  flex: 1;
  padding: 8rpx 24rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 60rpx;
  margin-top: 8rpx;
  background: linear-gradient(180deg, rgba(255, 251, 245, 0.95), rgba(243, 251, 246, 0.92));
  border-radius: 32rpx;
  box-shadow: 0 12rpx 30rpx rgba(194, 170, 157, 0.12);
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #2F2A26;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8D7F76;
}

/* 动态卡片 */
.post-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  transition: transform 0.15s ease;
  background: linear-gradient(180deg, #FFFDFC, #FFF9F4);
}

.post-card:active {
  transform: scale(0.98);
}

.post-card.own-post {
  background: linear-gradient(180deg, #FFF9F5, #FFFCF8);
  border: 1rpx solid rgba(245, 107, 111, 0.18);
  box-shadow: 0 14rpx 34rpx rgba(245, 107, 111, 0.1);
}

.post-card:nth-child(3n + 1) {
  background: linear-gradient(180deg, #FFFDFC, #FFF7EF);
}

.post-card:nth-child(3n + 2) {
  background: linear-gradient(180deg, #FFFEFC, #F3FBF6);
}

.post-card:nth-child(3n) {
  background: linear-gradient(180deg, #FFFEFC, #F3F8FF);
}

.post-header {
  margin-bottom: 16rpx;
}

.post-author {
  gap: 16rpx;
}

.author-info {
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2F2A26;
}

.post-time {
  font-size: 22rpx;
  color: #A08F84;
}

/* 动态内容 */
.post-content {
  margin-bottom: 16rpx;
}

/* 语音气泡 */
.voice-bubble {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #AEE483, #97D86E);
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  gap: 12rpx;
  min-width: 160rpx;
}

.voice-icon {
  font-size: 32rpx;
}

.voice-bars {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.vbar {
  width: 6rpx;
  border-radius: 3rpx;
  background: rgba(0, 0, 0, 0.2);
}

.vbar:nth-child(1) { height: 10rpx; }
.vbar:nth-child(2) { height: 22rpx; }
.vbar:nth-child(3) { height: 30rpx; }
.vbar:nth-child(4) { height: 18rpx; }
.vbar:nth-child(5) { height: 12rpx; }

.voice-duration {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.45);
}

/* 语音播放动画 */
.voice-bubble.playing {
  background: linear-gradient(135deg, #A2DD75, #8ED15F);
}

.voice-bubble.playing .vbar {
  animation: voiceWave 0.8s ease-in-out infinite;
}

.voice-bubble.playing .vbar:nth-child(1) { animation-delay: 0s; }
.voice-bubble.playing .vbar:nth-child(2) { animation-delay: 0.1s; }
.voice-bubble.playing .vbar:nth-child(3) { animation-delay: 0.2s; }
.voice-bubble.playing .vbar:nth-child(4) { animation-delay: 0.3s; }
.voice-bubble.playing .vbar:nth-child(5) { animation-delay: 0.4s; }

@keyframes voiceWave {
  0%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(2.2); }
}

/* 图片 */
.post-image {
  width: 90%;
  height: 400rpx;
  border-radius: 24rpx;
  background: #F1EAE3;
  margin: 0 auto;
  display: block;
}

.post-image.text-photo {
  width: 100%;
  height: 360rpx;
  margin-top: 16rpx;
}

.post-image.drawing {
  width: 70%;
  height: 360rpx;
  background: #FFFFFF;
  border: 2rpx solid #F0E4DA;
  box-shadow: 0 8rpx 18rpx rgba(176, 156, 145, 0.12);
}

/* 文字动态 */
.text-content {
  padding: 8rpx 0;
}

.text-body {
  font-size: 32rpx;
  color: #2F2A26;
  line-height: 1.7;
  word-break: break-all;
}

.text-mood {
  margin-top: 12rpx;
}

.text-mood .mood-emoji {
  font-size: 44rpx;
}

.photo-text {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #5A4E47;
}

.mood-emoji {
  font-size: 36rpx;
}

/* 互动栏 */
.post-actions {
  gap: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F3E6DB;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  background: linear-gradient(135deg, #FFF4EC, #FFF9F3);
  border-radius: 999rpx;
}

.action-btn.liked .action-icon {
  transform: scale(1.1);
}

.action-icon {
  font-size: 36rpx;
  transition: transform 0.2s;
}

/* 点赞动画 */
.action-btn.like-anim .action-icon {
  animation: likePop 0.4s ease;
}

@keyframes likePop {
  0% { transform: scale(1); }
  30% { transform: scale(1.4); }
  60% { transform: scale(0.9); }
  100% { transform: scale(1); }
}

.action-count {
  font-size: 26rpx;
  color: #8B7D74;
}

.action-btn.liked .action-count {
  color: #F56B6F;
}

/* 列表底部 */
.list-bottom {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 48rpx 0;
}

.bottom-line {
  width: 60rpx;
  height: 2rpx;
  background: #E2D5CA;
}

.bottom-text {
  font-size: 24rpx;
  color: #B6A79B;
}

/* 发动态浮球 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F56B6F, #FF8E77);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 34rpx rgba(245, 107, 111, 0.28);
  z-index: 50;
  transition: transform 0.15s, box-shadow 0.15s;
}

.fab-btn:active {
  transform: scale(0.9);
  box-shadow: 0 8rpx 18rpx rgba(245, 107, 111, 0.22);
}

.fab-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* 快速emoji回应条 */
.quick-react-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  transition: opacity 0.2s;
}

.quick-react-bar.show {
  opacity: 1;
}

.quick-react-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.3);
}

.quick-react-panel {
  position: relative;
  background: #FFFDF9;
  border-radius: 36rpx 36rpx 0 0;
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  width: 100%;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.quick-react-bar.show .quick-react-panel {
  transform: translateY(0);
}

.quick-react-hint {
  display: block;
  font-size: 26rpx;
  color: #8D7F76;
  text-align: center;
  margin-bottom: 24rpx;
}

.quick-react-options {
  display: flex;
  justify-content: space-around;
}

.quick-react-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #FFF1E7, #FFF8EE);
  transition: transform 0.15s;
}

.quick-react-item:active {
  transform: scale(1.3);
  background: #FFEAE6;
}

.quick-react-emoji {
  font-size: 48rpx;
}

/* 家长验证码弹窗 */
.parent-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.parent-modal {
  width: 560rpx;
  background: #FFFDF9;
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 18rpx 36rpx rgba(89, 73, 65, 0.2);
}

.parent-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2F2A26;
  margin-bottom: 16rpx;
}

.parent-modal-desc {
  font-size: 26rpx;
  color: #8C7F76;
  margin-bottom: 32rpx;
}

.parent-code-input {
  width: 100%;
  height: 80rpx;
  background: #FFF4EC;
  border-radius: 16rpx;
  text-align: center;
  font-size: 36rpx;
  letter-spacing: 16rpx;
  color: #2F2A26;
  margin-bottom: 12rpx;
}

.parent-code-error {
  font-size: 24rpx;
  color: #C8646A;
  margin-bottom: 12rpx;
  height: 32rpx;
}

.parent-modal-btns {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-top: 16rpx;
}

.parent-modal-btn {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-cancel {
  background: #FFF4EC;
  color: #8C7F76;
}

.btn-confirm {
  background: linear-gradient(135deg, #F56B6F, #FF8E77);
  color: #FFFFFF;
  box-shadow: 0 8rpx 18rpx rgba(245, 107, 111, 0.22);
}

.btn-cancel:active {
  background: #E8E8E8;
}

.btn-confirm:active {
  opacity: 0.85;
}
