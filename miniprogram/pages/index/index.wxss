/* pages/index/index.wxss */
.page-index {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F5F5;
}

/* 无身份引导页 */
.no-identity {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 0 60rpx;
  background: #FFFFFF;
}

.no-identity-emoji {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.no-identity-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.no-identity-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 48rpx;
  text-align: center;
  line-height: 1.6;
}

.no-identity-btn {
  width: 360rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
}

.no-identity-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.no-identity-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.grade-tag {
  font-size: 22rpx;
  color: #999;
  background: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.switch-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
}

.switch-text {
  font-size: 24rpx;
  color: #666;
}

.switch-icon {
  font-size: 20rpx;
  color: #999;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.parent-mode-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 14rpx;
  border-radius: 20rpx;
  background: #F5F5F5;
  transition: all 0.2s;
}

.parent-mode-btn.active {
  background: #E8F5E9;
}

.parent-mode-icon {
  font-size: 28rpx;
}

.parent-mode-text {
  font-size: 22rpx;
  color: #4CAF50;
  font-weight: 500;
}

.parent-mode-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: linear-gradient(90deg, #E8F5E9, #F1F8E9);
  border-bottom: 2rpx solid #C8E6C9;
}

.banner-icon {
  font-size: 28rpx;
}

.banner-text {
  font-size: 24rpx;
  color: #388E3C;
  font-weight: 500;
}

.banner-close {
  font-size: 28rpx;
  color: #999;
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
}

/* 账户切换面板 */
.account-switcher {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.switcher-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
}

.switcher-panel {
  position: absolute;
  top: 120rpx;
  left: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  min-width: 400rpx;
}

.switcher-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.switcher-item {
  display: flex;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
}

.switcher-tap-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.switcher-edit {
  font-size: 24rpx;
  color: #4ECDC4;
  padding: 8rpx 16rpx;
  background: #4ECDC410;
  border-radius: 16rpx;
}

.switcher-item.active {
  background: #FFF0F0;
}

.switcher-name {
  font-size: 30rpx;
  color: #333;
}

.switcher-grade {
  font-size: 22rpx;
  color: #999;
}

.switcher-check {
  margin-left: auto;
  color: #FF6B6B;
  font-size: 28rpx;
  font-weight: bold;
}

.switcher-add {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  margin-top: 8rpx;
  border-top: 2rpx solid #F0F0F0;
}

.switcher-add-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FF6B6B;
  color: #FFFFFF;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 48rpx;
  text-align: center;
}

.switcher-add-text {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 500;
}

/* 动态列表 */
.post-list {
  flex: 1;
  padding: 20rpx 24rpx;
  padding-bottom: 140rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 60rpx;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 动态卡片 */
.post-card {
  margin-bottom: 24rpx;
  transition: transform 0.15s ease;
}

.post-card:active {
  transform: scale(0.98);
}

.post-card.own-post {
  border-left: 6rpx solid #FF6B6B;
}

.post-header {
  margin-bottom: 16rpx;
}

.post-author {
  gap: 16rpx;
}

.author-info {
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.post-time {
  font-size: 22rpx;
  color: #999;
}

/* 动态内容 */
.post-content {
  margin-bottom: 16rpx;
}

/* 语音气泡 */
.voice-bubble {
  display: flex;
  align-items: center;
  background: #95EC69;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  gap: 12rpx;
  min-width: 160rpx;
}

.voice-icon {
  font-size: 32rpx;
}

.voice-bars {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.vbar {
  width: 6rpx;
  border-radius: 3rpx;
  background: rgba(0, 0, 0, 0.2);
}

.vbar:nth-child(1) { height: 10rpx; }
.vbar:nth-child(2) { height: 22rpx; }
.vbar:nth-child(3) { height: 30rpx; }
.vbar:nth-child(4) { height: 18rpx; }
.vbar:nth-child(5) { height: 12rpx; }

.voice-duration {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.45);
}

/* 语音播放动画 */
.voice-bubble.playing {
  background: #8BE55A;
}

.voice-bubble.playing .vbar {
  animation: voiceWave 0.8s ease-in-out infinite;
}

.voice-bubble.playing .vbar:nth-child(1) { animation-delay: 0s; }
.voice-bubble.playing .vbar:nth-child(2) { animation-delay: 0.1s; }
.voice-bubble.playing .vbar:nth-child(3) { animation-delay: 0.2s; }
.voice-bubble.playing .vbar:nth-child(4) { animation-delay: 0.3s; }
.voice-bubble.playing .vbar:nth-child(5) { animation-delay: 0.4s; }

@keyframes voiceWave {
  0%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(2.2); }
}

/* 图片 */
.post-image {
  width: 90%;
  height: 400rpx;
  border-radius: 16rpx;
  background: #F0F0F0;
  margin: 0 auto;
  display: block;
}

.post-image.drawing {
  width: 70%;
  height: 360rpx;
  background: #FFFFFF;
  border: 2rpx solid #E8E8E8;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

/* 文字动态 */
.text-content {
  padding: 8rpx 0;
}

.text-body {
  font-size: 32rpx;
  color: #333;
  line-height: 1.7;
  word-break: break-all;
}

.text-mood {
  margin-top: 12rpx;
}

.text-mood .mood-emoji {
  font-size: 44rpx;
}

.photo-text {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.mood-emoji {
  font-size: 36rpx;
}

/* 互动栏 */
.post-actions {
  gap: 32rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F5F5F5;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.action-btn.liked .action-icon {
  transform: scale(1.1);
}

.action-icon {
  font-size: 36rpx;
  transition: transform 0.2s;
}

/* 点赞动画 */
.action-btn.like-anim .action-icon {
  animation: likePop 0.4s ease;
}

@keyframes likePop {
  0% { transform: scale(1); }
  30% { transform: scale(1.4); }
  60% { transform: scale(0.9); }
  100% { transform: scale(1); }
}

.action-count {
  font-size: 26rpx;
  color: #999;
}

.action-btn.liked .action-count {
  color: #FF6B6B;
}

/* 列表底部 */
.list-bottom {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 48rpx 0;
}

.bottom-line {
  width: 60rpx;
  height: 2rpx;
  background: #E0E0E0;
}

.bottom-text {
  font-size: 24rpx;
  color: #CCC;
}

/* 发动态浮球 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
  z-index: 50;
  transition: transform 0.15s, box-shadow 0.15s;
}

.fab-btn:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
}

.fab-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* 快速emoji回应条 */
.quick-react-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  transition: opacity 0.2s;
}

.quick-react-bar.show {
  opacity: 1;
}

.quick-react-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.3);
}

.quick-react-panel {
  position: relative;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  width: 100%;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.quick-react-bar.show .quick-react-panel {
  transform: translateY(0);
}

.quick-react-hint {
  display: block;
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 24rpx;
}

.quick-react-options {
  display: flex;
  justify-content: space-around;
}

.quick-react-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #F5F5F5;
  transition: transform 0.15s;
}

.quick-react-item:active {
  transform: scale(1.3);
  background: #FFE8E8;
}

.quick-react-emoji {
  font-size: 48rpx;
}

/* 家长验证码弹窗 */
.parent-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.parent-modal {
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.parent-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.parent-modal-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.parent-code-input {
  width: 100%;
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  text-align: center;
  font-size: 36rpx;
  letter-spacing: 16rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.parent-code-error {
  font-size: 24rpx;
  color: #FF6B6B;
  margin-bottom: 12rpx;
  height: 32rpx;
}

.parent-modal-btns {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-top: 16rpx;
}

.parent-modal-btn {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-cancel {
  background: #F5F5F5;
  color: #999;
}

.btn-confirm {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.btn-cancel:active {
  background: #E8E8E8;
}

.btn-confirm:active {
  opacity: 0.85;
}
