/* pages/draw/draw.wxss - 画板页面 */
.page-draw {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #FFF7EC, #F4FBF6);
}

.draw-canvas {
  flex: 1;
  width: 100%;
  background: #FFFFFF;
  border-bottom-left-radius: 28rpx;
  border-bottom-right-radius: 28rpx;
}

.toolbar {
  background: linear-gradient(180deg, rgba(255, 252, 248, 0.98), rgba(241, 249, 244, 0.96));
  border-top: 1rpx solid #F0E4DA;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -10rpx 24rpx rgba(194, 170, 157, 0.12);
}

.tool-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.tool-row:last-child {
  margin-bottom: 0;
}

.tool-label {
  font-size: 24rpx;
  color: #8C7F76;
  width: 64rpx;
  flex-shrink: 0;
}

/* 颜色选择 */
.color-options {
  display: flex;
  gap: 16rpx;
  flex: 1;
}

.color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  border: 4rpx solid transparent;
}

.color-dot.active {
  border-color: #2F2A26;
  transform: scale(1.15);
}

.color-dot.dim {
  opacity: 0.3;
}

.color-check {
  font-size: 24rpx;
  color: #FFFFFF;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.3);
}

/* 粗细选择 */
.size-options {
  display: flex;
  gap: 12rpx;
  flex: 1;
}

.size-btn {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #FFF8F2;
  border: 2rpx solid #F0E4DA;
  font-size: 24rpx;
  color: #6B5F58;
  transition: all 0.2s;
}

.size-btn.active {
  background: #F56B6F;
  border-color: #F56B6F;
  color: #FFFFFF;
}

.size-btn.dim {
  opacity: 0.3;
}

/* 操作按钮 */
.action-row {
  justify-content: space-between;
}

.action-btns {
  display: flex;
  gap: 12rpx;
}

.tool-action {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  background: #FFF8F2;
  border: 2rpx solid #F0E4DA;
  font-size: 22rpx;
  color: #6B5F58;
  transition: all 0.2s;
}

.tool-action.active {
  background: #FFF1DE;
  border-color: #F6C969;
  color: #B37D1A;
}

.tool-action.danger {
  color: #C8646A;
}

.tool-action.disabled {
  opacity: 0.3;
}

.tool-action:active:not(.disabled) {
  transform: scale(0.95);
}

/* 完成按钮 */
.finish-btn {
  background: linear-gradient(135deg, #F56B6F, #FF8E77);
  color: #FFFFFF;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 18rpx rgba(245, 107, 111, 0.22);
}

.finish-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}
