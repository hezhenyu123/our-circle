/* pages/detail/detail.wxss */
.page-detail {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #FFF0E0 0, #FFF8EF 190rpx, #F3F9FF 190rpx, #F6F3EE 100%);
  padding: 20rpx 24rpx 140rpx;
  box-sizing: border-box;
}

/* 动态卡片 */
.detail-card {
  background: linear-gradient(180deg, rgba(255, 252, 248, 0.98), rgba(246, 250, 255, 0.93));
  padding: 28rpx;
  margin-bottom: 18rpx;
  border-radius: 32rpx;
  box-shadow: 0 12rpx 30rpx rgba(194, 170, 157, 0.12);
}

.detail-header {
  margin-bottom: 20rpx;
}

.author-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.delete-btn {
  margin-left: auto;
  padding: 12rpx;
  opacity: 0.5;
}

.delete-btn:active {
  opacity: 1;
}

.delete-icon {
  font-size: 28rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.author-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2F2A26;
}

.post-time {
  font-size: 22rpx;
  color: #9A8C82;
}

/* 动态内容 */
.detail-content {
  margin-bottom: 20rpx;
}

.voice-bubble {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #AEE483, #97D86E);
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  min-width: 160rpx;
  transition: background 0.2s;
}

.voice-icon {
  font-size: 32rpx;
}

.voice-bars {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.vbar {
  width: 6rpx;
  border-radius: 3rpx;
  background: rgba(0, 0, 0, 0.2);
}

.vbar:nth-child(1) { height: 10rpx; }
.vbar:nth-child(2) { height: 22rpx; }
.vbar:nth-child(3) { height: 30rpx; }
.vbar:nth-child(4) { height: 18rpx; }
.vbar:nth-child(5) { height: 12rpx; }

.voice-duration {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.45);
}

/* 语音播放动画 */
.voice-bubble.playing {
  background: linear-gradient(135deg, #A2DD75, #8ED15F);
}

.voice-bubble.playing .vbar {
  animation: voiceWave 0.8s ease-in-out infinite;
}

.voice-bubble.playing .vbar:nth-child(1) { animation-delay: 0s; }
.voice-bubble.playing .vbar:nth-child(2) { animation-delay: 0.1s; }
.voice-bubble.playing .vbar:nth-child(3) { animation-delay: 0.2s; }
.voice-bubble.playing .vbar:nth-child(4) { animation-delay: 0.3s; }
.voice-bubble.playing .vbar:nth-child(5) { animation-delay: 0.4s; }

@keyframes voiceWave {
  0%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(2.2); }
}

.emoji-stickers {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.sticker {
  font-size: 28rpx;
  background: #FFF6DE;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.detail-image {
  width: 100%;
  height: 500rpx;
  border-radius: 24rpx;
  margin: 0 auto;
  display: block;
}

.detail-image.text-photo {
  height: 420rpx;
  margin-top: 18rpx;
}

.detail-image.drawing {
  width: 78%;
  height: 400rpx;
  background: #FFFFFF;
  border: 2rpx solid #F0E4DA;
  box-shadow: 0 8rpx 18rpx rgba(176, 156, 145, 0.12);
}

.photo-caption {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.mood {
  font-size: 36rpx;
}

.caption-text {
  font-size: 28rpx;
  color: #5A4E47;
}

.text-body {
  font-size: 34rpx;
  color: #2F2A26;
  line-height: 1.7;
  word-break: break-all;
}

.text-mood {
  margin-top: 16rpx;
}

.mood-emoji-lg {
  font-size: 48rpx;
}

/* 互动栏 */
.detail-actions {
  display: flex;
  gap: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #F3E6DB;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  background: #FFF5EE;
  border-radius: 999rpx;
}

.action-icon {
  font-size: 32rpx;
}

.action-count {
  font-size: 26rpx;
  color: #8B7D74;
}

.action-btn.liked .action-count {
  color: #F56B6F;
}

/* 评论区 */
.comment-section {
  background: linear-gradient(180deg, rgba(255, 252, 248, 0.98), rgba(243, 250, 245, 0.93));
  padding: 28rpx;
  border-radius: 32rpx;
  box-shadow: 0 12rpx 30rpx rgba(194, 170, 157, 0.1);
}

.comment-header {
  margin-bottom: 20rpx;
}

.comment-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2F2A26;
}

.empty-comments {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #9A8C82;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
}

.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.comment-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.comment-body {
  flex: 1;
}

.comment-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #645851;
  display: block;
  margin-bottom: 4rpx;
}

.comment-content {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.comment-emoji {
  font-size: 36rpx;
}

.comment-text {
  font-size: 28rpx;
  color: #2F2A26;
}

.comment-time {
  font-size: 20rpx;
  color: #B6A79B;
  margin-top: 4rpx;
  display: block;
}

/* 底部评论栏 */
.comment-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 252, 248, 0.95);
  border-top: 1rpx solid #F0E4DA;
  z-index: 50;
}

.comment-input-fake {
  background: #FFF2EA;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
}

.placeholder {
  font-size: 28rpx;
  color: #B7A99D;
}

/* 评论面板 */
.comment-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s;
}

.comment-panel-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.comment-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFDF9;
  border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.comment-panel.show {
  transform: translateY(0);
}

.comment-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2F2A26;
}

.panel-submit {
  background: linear-gradient(135deg, #F56B6F, #FF8E77);
  color: #FFFFFF;
  padding: 10rpx 32rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
}

.panel-submit.disabled {
  background: #D6CAC1;
}

/* emoji选择器 */
.emoji-picker {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.emoji-option {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF4EC;
  border-radius: 16rpx;
  font-size: 36rpx;
  border: 3rpx solid transparent;
}

.emoji-option.selected {
  border-color: #F56B6F;
  background: #FFEAE6;
}

/* 文字输入 */
.comment-text-input-wrap {
  background: #FFF4EC;
  border-radius: 16rpx;
  padding: 16rpx;
}

.comment-textarea {
  width: 100%;
  min-height: 100rpx;
  font-size: 28rpx;
  line-height: 44rpx;
  box-sizing: border-box;
  padding: 0;
}

/* 家长验证码弹窗 */
.parent-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.parent-modal {
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.parent-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2F2A26;
  margin-bottom: 16rpx;
}

.parent-modal-desc {
  font-size: 26rpx;
  color: #8C7F76;
  margin-bottom: 32rpx;
}

.parent-code-input {
  width: 100%;
  height: 80rpx;
  background: #FFF4EC;
  border-radius: 16rpx;
  text-align: center;
  font-size: 36rpx;
  letter-spacing: 16rpx;
  color: #2F2A26;
  margin-bottom: 12rpx;
}

.parent-code-error {
  font-size: 24rpx;
  color: #C8646A;
  margin-bottom: 12rpx;
  height: 32rpx;
}

.parent-modal-btns {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-top: 16rpx;
}

.parent-modal-btn {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-cancel {
  background: #FFF4EC;
  color: #8C7F76;
}

.btn-confirm {
  background: linear-gradient(135deg, #F56B6F, #FF8E77);
  color: #FFFFFF;
  box-shadow: 0 8rpx 18rpx rgba(245, 107, 111, 0.22);
}

.btn-cancel:active {
  background: #E8E8E8;
}

.btn-confirm:active {
  opacity: 0.85;
}
