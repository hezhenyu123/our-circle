/* app.wxss - 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #F6F3EE;
  color: #2F2A26;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 全局工具类 */
.container {
  padding: 24rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 圆角卡片 */
.card {
  background: #FFFCF8;
  border-radius: 30rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(243, 226, 215, 0.9);
  box-shadow: 0 12rpx 32rpx rgba(194, 170, 157, 0.12);
  transition: transform 0.15s ease;
}

.card:active {
  transform: scale(0.985);
}

/* 头像 */
.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  overflow: hidden;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.45);
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #F56B6F, #FF8E77);
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 26rpx rgba(245, 107, 111, 0.24);
}

.btn-primary::after {
  border: none;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
